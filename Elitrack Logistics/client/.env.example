# Optional hard override for all API traffic
# REACT_APP_API_URL=http://localhost:4001

# Primary cutover switch (default in code is true)
REACT_APP_USE_NEST_API=true
# Optional alias for non-CRA setups
USE_NEST_API=true

# Target URLs for each backend
REACT_APP_NEST_API_URL=http://localhost:4001
REACT_APP_EXPRESS_API_URL=http://localhost:5000/api
